# 后端环境变量（复制为 .env 并填入真实值；.env 不要提交到 git）
# 三选一即可：设了哪个 key 就用哪个 provider（优先级 DeepSeek > OpenAI兼容 > Anthropic）

# —— 方案A：DeepSeek（便宜，OpenAI 兼容，推荐用于客服问答）——
# 申请：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# 模型可选 deepseek-chat（默认）/ deepseek-reasoner
# CHAT_MODEL=deepseek-chat

# —— 方案B：Anthropic Claude ——
# 申请：https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# CHAT_MODEL=claude-haiku-4-5-20251001

# —— 方案C：其它 OpenAI 兼容服务（通义/智谱/本地等）——
# OPENAI_API_KEY=xxxxxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o-mini

# 后端端口（可选，默认 8787）
PORT=8787

# 实时到站数据源（可选）：默认 mock（模拟数据）。
# 拿到苏州有轨电车官方实时接口后，设为 official 并在 server/arrivals.js 实现 official()，前端无需改动。
# ARRIVALS_PROVIDER=mock
# ARRIVALS_API_URL=
# ARRIVALS_API_KEY=
# ARRIVALS_HEADWAY_SEC=450   # 发车间隔（秒），mock 用，默认 7.5 分钟

# 登录 token 签名密钥（生产务必改成随机强值）
# AUTH_SECRET=change-me
# SQLite 文件路径（可选，指向挂载磁盘可持久化）
# DB_PATH=/data/data.db
