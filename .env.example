# 后端环境变量（复制为 .env 并填入真实值；.env 不要提交到 git）

# 你的 Anthropic API 密钥（必填，AI 问答才能工作）
# 申请地址：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 对话使用的模型（可选）。默认 Haiku：快且便宜，适合客服问答。
# 想要更强可改为 claude-sonnet-4-6 或 claude-opus-4-8
CHAT_MODEL=claude-haiku-4-5-20251001

# 后端端口（可选，默认 8787）
PORT=8787
